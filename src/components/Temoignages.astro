---
import { temoignages } from '../data/temoignages.js';
---

<section>
  <div class="mb-8">
    <span class="text-xs uppercase tracking-widest font-semibold block mb-2" style="color: #cfbb99;">
      Témoignages
    </span>
    <h2 class="text-3xl md:text-4xl tracking-tight" style="font-family: 'Playfair Display', serif;">
      Découvre leurs témoignages en vidéo
    </h2>
    <p class="text-sm font-light leading-relaxed mt-3 max-w-2xl text-justify" style="color: #e9dcc8;">
      Clique sur une vignette pour lancer la vidéo.
    </p>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
    {temoignages.map(({ nom, citation, photo, video }) => (
      <button
        class="video-card video-open rounded-2xl p-3 border transition-all text-left border-white/10 hover:border-white/20"
        style="background: rgba(255,255,255,0.05); box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
        data-video={video}
        data-title={nom}
        type="button"
      >
        <div
          class="relative rounded-xl overflow-hidden border border-white/10"
          style="aspect-ratio: 3/4; background: rgba(255,255,255,0.06);"
        >
          <img class="w-full h-full object-cover" src={photo} alt={nom} />
          <span
            class="absolute bottom-2 left-2 w-8 h-8 rounded-full flex items-center justify-center text-xs text-white"
            style="background: rgba(12,85,126,0.9); box-shadow: 0 8px 18px rgba(0,0,0,0.25);"
          >
            ▶
          </span>
        </div>
        <h3 class="text-xs font-medium mt-2.5" style="font-family: 'Playfair Display', serif;">{nom}</h3>
        <p class="text-xs font-light leading-snug" style="color: #e9dcc8;">"{citation}"</p>
      </button>
    ))}
  </div>
</section>

<!-- Video Modal -->
<div class="modal" id="videoModal" aria-hidden="true">
  <div class="absolute inset-0" style="background: rgba(0,0,0,0.68);" data-close="true"></div>
  <div
    class="relative z-10 w-full max-w-lg mx-4 rounded-3xl p-4 border border-white/10"
    style="background: #0b3954; box-shadow: 0 30px 90px rgba(0,0,0,0.5);"
  >
    <button
      class="absolute top-3 right-4 w-10 h-10 rounded-full flex items-center justify-center border-0 text-xl cursor-pointer text-white"
      style="background: rgba(255,255,255,0.14);"
      type="button"
      data-close="true"
    >
      ×
    </button>
    <h3 class="text-base font-medium mb-3" id="modalTitle" style="font-family: 'Playfair Display', serif;">
      Vidéo
    </h3>
    <video
      id="modalVideo"
      controls
      playsinline
      preload="metadata"
      class="w-full rounded-2xl"
      style="max-height: 80vh; background: #000;"
    ></video>
  </div>
</div>

<script>
  const modal = document.getElementById('videoModal') as HTMLElement;
  const modalVideo = document.getElementById('modalVideo') as HTMLVideoElement;
  const modalTitle = document.getElementById('modalTitle') as HTMLElement;

  document.querySelectorAll('.video-open').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      const src = el.dataset.video ?? '';
      const title = el.dataset.title ?? 'Vidéo';
      modalTitle.textContent = title;
      modalVideo.innerHTML = '';
      modalVideo.src = src;
      modal.setAttribute('aria-hidden', 'false');
      modalVideo.play().catch(() => {});
    });
  });

  modal.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (target.dataset.close === 'true') {
      modal.setAttribute('aria-hidden', 'true');
      modalVideo.pause();
      modalVideo.removeAttribute('src');
      modalVideo.load();
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      modal.setAttribute('aria-hidden', 'true');
      modalVideo.pause();
      modalVideo.removeAttribute('src');
      modalVideo.load();
    }
  });
</script>
