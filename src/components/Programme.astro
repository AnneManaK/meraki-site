---
const jours = [
  {
    num: 'Jour 1',
    titre: 'Arriver',
    texte: "Quitter le rythme habituel, poser ton intention, souffler et entrer dans l'espace.",
  },
  {
    num: 'Jour 2',
    titre: 'Ressentir',
    texte: 'Explorer le corps, les sensations, les émotions et les mouvements intérieurs qui cherchent à se dire.',
  },
  {
    num: 'Jour 3',
    titre: 'Ouvrir',
    texte: "Mettre de la conscience sur ce qui freine, ce qui appelle, ce qui demande à évoluer ou à être relâché.",
  },
  {
    num: 'Jour 4',
    titre: 'Intégrer',
    texte: "Ancrer les prises de conscience et repartir avec plus de clarté, de souffle et de direction.",
  },
];
---

<section>
  <div class="mb-8">
    <span class="text-xs uppercase tracking-widest font-semibold block mb-2" style="color: #cfbb99;">
      Déroulé
    </span>
    <h2 class="text-3xl md:text-4xl tracking-tight" style="font-family: 'Playfair Display', serif;">
      Le fil des 4 jours
    </h2>
    <p class="text-sm font-light leading-relaxed mt-3 max-w-2xl" style="color: #e9dcc8;">
      Tu n'as pas besoin de tout prévoir pour vivre pleinement l'expérience. Mais voici des repères pour t'aider à te
      projeter.
    </p>
  </div>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {jours.map(({ num, titre, texte }) => (
      <div
        class="rounded-2xl p-5 border transition-colors border-white/10 hover:border-white/20"
        style="background: rgba(255,255,255,0.05); box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
      >
        <span class="text-xs uppercase tracking-widest font-semibold block mb-3" style="color: #cfbb99;">
          {num}
        </span>
        <h3 class="text-base font-medium mb-2" style="font-family: 'Playfair Display', serif;">{titre}</h3>
        <p class="text-sm font-light leading-relaxed" style="color: #e9dcc8;">{texte}</p>
      </div>
    ))}
  </div>
</section>
