---
import { sessions } from '../data/sessions.js';
---

<section id="infos">
  <div class="mb-8">
    <span class="text-xs uppercase tracking-widest font-semibold block mb-2" style="color: #cfbb99;">
      Infos pratiques
    </span>
    <h2 class="text-3xl md:text-4xl tracking-tight" style="font-family: 'Playfair Display', serif;">
      Deux dates, deux lieux, un même esprit
    </h2>
    <p class="text-sm font-light leading-relaxed mt-3 w-full text-justify" style="color: #e9dcc8;">
      Deux immersions sont proposées en 2026, dans des lieux authentiques en Mayenne, toujours en petit groupe pour
      préserver la qualité de présence et d'accompagnement.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    {sessions.map((s, i) => (
      <div
        class="rounded-2xl p-6 border border-white/10"
        style={`background: rgba(255,255,255,${i === 1 ? '0.08' : '0.05'}); box-shadow: 0 8px 24px rgba(0,0,0,0.12);`}
      >
        <div class="flex items-center gap-2 mb-3">
          <iconify-icon icon="solar:calendar-linear" width="18" style="color: #cfbb99;" stroke-width="1.5"
          ></iconify-icon>
          <h3 class="text-base font-medium" style="font-family: 'Playfair Display', serif;">{s.dates}</h3>
        </div>
        <p class="text-sm font-light leading-relaxed text-justify" style="color: #e9dcc8;">
          <strong class="font-medium text-white">Lieu :</strong> {s.lieu}
          <br />
          <strong class="font-medium text-white">Format :</strong> {s.format}
        </p>
      </div>
    ))}
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mt-5">
    <div
      class="md:col-span-2 rounded-2xl p-6 border border-white/10"
      style="background: rgba(255,255,255,0.06); box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
    >
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-5">
        <div>
          <span class="text-xs uppercase tracking-widest font-semibold block mb-2" style="color:#cfbb99;">
            Pré-inscriptions
          </span>
          <h3 class="text-xl mb-2" style="font-family:'Playfair Display', serif;">
            Les prochains séjours arrivent bientôt
          </h3>
          <p class="text-sm font-light leading-relaxed max-w-xl text-justify" style="color:#e9dcc8;">
            Laisse ton mail pour recevoir les prochaines dates et le lien d'inscription en avant-première.
          </p>
        </div>
        <form class="flex flex-col sm:flex-row gap-3 w-full md:w-auto">
          <input
            type="email"
            placeholder="Ton adresse e-mail"
            class="px-5 py-3 rounded-xl text-sm min-w-[260px] outline-none border border-white/10"
            style="background:rgba(255,255,255,0.08); color:white;"
          />
          <button
            type="submit"
            class="px-6 py-3 rounded-xl text-xs uppercase tracking-wide font-medium transition-all hover:opacity-90"
            style="background:#cfbb99; color:#111;"
          >
            Être informé(e)
          </button>
        </form>
      </div>
    </div>

    <div
      class="rounded-2xl p-6 border border-white/10"
      style="background: rgba(255,255,255,0.05); box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
    >
      <div class="flex items-center gap-2 mb-4">
        <iconify-icon icon="solar:check-circle-linear" width="18" style="color: #cfbb99;" stroke-width="1.5"
        ></iconify-icon>
        <h3 class="text-base font-medium">Ce qui est inclus</h3>
      </div>
      <ul class="space-y-2.5 text-sm font-light" style="color: #e9dcc8;">
        <li class="flex gap-2"><span style="color: #cfbb99;">·</span>L'accompagnement pendant toute l'immersion.</li>
        <li class="flex gap-2"><span style="color: #cfbb99;">·</span>Les ateliers, pratiques et temps collectifs.</li>
        <li class="flex gap-2"><span style="color: #cfbb99;">·</span>L'hébergement sur place.</li>
        <li class="flex gap-2"><span style="color: #cfbb99;">·</span>Les repas pendant le séjour.</li>
      </ul>
    </div>

    <div
      class="rounded-2xl p-6 border border-white/10"
      style="background: rgba(255,255,255,0.08); box-shadow: 0 8px 24px rgba(0,0,0,0.12);"
    >
      <div class="flex items-center gap-2 mb-4">
        <iconify-icon
          icon="solar:info-circle-linear"
          width="18"
          style="color: rgba(233,220,200,0.5);"
          stroke-width="1.5"
        ></iconify-icon>
        <h3 class="text-base font-medium">Ce qui n'est pas inclus</h3>
      </div>
      <ul class="space-y-2.5 text-sm font-light" style="color: #e9dcc8;">
        <li class="flex gap-2"><span style="color: rgba(233,220,200,0.4);">·</span>Le transport jusqu'au lieu.</li>
        <li class="flex gap-2"><span style="color: rgba(233,220,200,0.4);">·</span>Les dépenses personnelles.</li>
        <li class="flex gap-2">
          <span style="color: rgba(233,220,200,0.4);">·</span>Tout ce qui n'est pas mentionné explicitement dans "ce qui est inclus".
        </li>
      </ul>
    </div>
  </div>
</section>
